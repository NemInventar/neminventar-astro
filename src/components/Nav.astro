---
// Delt navigation. Anker-links peger på forsidens sektioner og er base-bevidste
// (import.meta.env.BASE_URL), så de virker både på custom domain ('/') og GitHub
// projekt-side ('/repo/').
const base = import.meta.env.BASE_URL; // slutter med '/'
---
<nav><div class="wrap nav-in">
  <a href={base} class="brand">NEM<b>·</b>INVENTAR</a>
  <div class="nav-links">
    <a href={`${base}#katalog`}>Arketyper</a>
    <a href={`${base}#projekter`}>Projekter</a>
    <a href={`${base}#staar-for`}>Sådan arbejder vi</a>
    <a href={`${base}#cert`}>Dokumentation</a>
    <a href={`${base}kontakt`} class="nav-cta">Få pris</a>
  </div>
</div></nav>
